@inherits LayoutComponentBase
@using BBF.Services
@using BBF.Data.Entities
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject UserContextService UserContext
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@implements IDisposable

<MudThemeProvider @bind-IsDarkMode="_isDarkMode" Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider MaxWidth="MaxWidth.Large" FullWidth="true" />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit"
                       Edge="Edge.Start" OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h5" Class="ml-3 d-none d-sm-flex">BBF</MudText>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                @if (UserContext.Groups.Count > 1)
                {
                    <MudSelect T="int?" Value="UserContext.ActiveGroupId"
                               ValueChanged="OnGroupChanged"
                               Variant="Variant.Outlined" Dense Margin="Margin.Dense"
                               Style="max-width: 160px; color: inherit;"
                               Class="mr-2">
                        @foreach (var group in UserContext.Groups)
                        {
                            <MudSelectItem T="int?" Value="@group.Id">@group.Name</MudSelectItem>
                        }
                    </MudSelect>
                }
                <MudText Typo="Typo.body2" Class="mr-3 d-none d-md-flex">@context.User.Identity?.Name</MudText>
                <form action="Account/Logout" method="post">
                    <AntiforgeryToken />
                    <input type="hidden" name="ReturnUrl" value="" />
                    <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit"
                                   ButtonType="ButtonType.Submit" title="Log out" />
                </form>
            </Authorized>
        </AuthorizeView>
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit" OnClick="ToggleDarkMode" title="Toggle theme" />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Breakpoint="Breakpoint.Md"
               ClipMode="DrawerClipMode.Always" Elevation="2"
               Variant="@DrawerVariant.Responsive">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Class="px-2 px-sm-4 pb-4">
        @Body
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">X</span>
</div>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode = true;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = Colors.Blue.Default,
            Secondary = Colors.Green.Accent4,
            AppbarBackground = Colors.Blue.Default,
        },
        PaletteDark = new PaletteDark()
        {
            Primary = Colors.Blue.Lighten1,
            Secondary = Colors.Green.Accent4,
        }
    };

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (userId is not null)
            {
                await UserContext.InitializeAsync(userId);
                StateHasChanged();
            }
        }
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        // Auto-close drawer on navigation for mobile (overlay mode)
        if (_drawerOpen)
        {
            _drawerOpen = false;
            InvokeAsync(StateHasChanged);
        }
    }

    private void OnGroupChanged(int? groupId)
    {
        if (groupId.HasValue)
            UserContext.SetActiveGroup(groupId.Value);
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
    private void ToggleDarkMode() => _isDarkMode = !_isDarkMode;

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
}
