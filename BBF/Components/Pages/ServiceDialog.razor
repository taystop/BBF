@using BBF.Data.Entities

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@(Service.Id == 0 ? "Add Service" : "Edit Service")</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="Service.Name" Label="Name" Required Variant="Variant.Outlined" Class="mb-3" />
        <MudTextField @bind-Value="Service.Url" Label="URL" Required Variant="Variant.Outlined" Class="mb-3"
                      Placeholder="https://10.69.1.5:8096" />
        <MudTextField @bind-Value="Service.Description" Label="Description" Variant="Variant.Outlined" Class="mb-3" />
        <MudTextField @bind-Value="Service.Category" Label="Category" Variant="Variant.Outlined" Class="mb-3"
                      Placeholder="Media, Infrastructure, Monitoring..." />
        <MudTextField @bind-Value="Service.Icon" Label="Material Icon" Variant="Variant.Outlined" Class="mb-3"
                      HelperText="MudBlazor Material icon name" />
        <MudTextField @bind-Value="Service.HealthCheckUrl" Label="Health Check URL" Variant="Variant.Outlined" Class="mb-3"
                      Placeholder="http://10.69.1.5:8096/health" HelperText="URL to ping for status checks" />
        <MudNumericField @bind-Value="Service.SortOrder" Label="Sort Order" Variant="Variant.Outlined" Class="mb-3" />
        <MudSwitch @bind-Value="Service.IsActive" Label="Active" Color="Color.Primary" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit"
                   Disabled="@(string.IsNullOrWhiteSpace(Service.Name) || string.IsNullOrWhiteSpace(Service.Url))">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public ServiceLink Service { get; set; } = new();

    private void Cancel() => MudDialog.Cancel();
    private void Submit() => MudDialog.Close(DialogResult.Ok(Service));
}
