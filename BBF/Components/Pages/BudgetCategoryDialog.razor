@using BBF.Data.Entities

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@(Category.Id == 0 ? "Add Category" : "Edit Category")</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="Category.Name" Label="Name" Required
                      Variant="Variant.Outlined" Class="mb-3" />
        <MudNumericField @bind-Value="Category.MonthlyLimit" Label="Monthly Limit ($)"
                         Variant="Variant.Outlined" Class="mb-3" Min="0"
                         Format="N2" />
        <MudColorPicker @bind-Value="_color" Label="Color"
                        Variant="Variant.Outlined" Class="mb-3"
                        disableAlpha />
        <MudTextField @bind-Value="Category.Icon" Label="Material Icon (optional)"
                      Variant="Variant.Outlined" Class="mb-3"
                      HelperText="e.g. ShoppingCart, Restaurant, Home" />
        <MudNumericField @bind-Value="Category.SortOrder" Label="Sort Order"
                         Variant="Variant.Outlined" Class="mb-3" />
        <MudSwitch @bind-Value="Category.IsActive" Label="Active" Color="Color.Primary" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit"
                   Disabled="@(string.IsNullOrWhiteSpace(Category.Name) || Category.MonthlyLimit <= 0)">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public BudgetCategory Category { get; set; } = new();

    private MudBlazor.Utilities.MudColor _color = new("#42a5f5");

    protected override void OnInitialized()
    {
        _color = new MudBlazor.Utilities.MudColor(Category.Color);
    }

    private void Cancel() => MudDialog.Cancel();
    private void Submit()
    {
        Category.Color = _color.Value;
        MudDialog.Close(DialogResult.Ok(Category));
    }
}
