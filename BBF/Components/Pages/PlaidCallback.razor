@page "/plaid-oauth-callback"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

<PageTitle>Connecting Bank... - BBF</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="py-8">
    <MudStack AlignItems="AlignItems.Center" Spacing="4">
        <MudProgressCircular Indeterminate Color="Color.Primary" Size="Size.Large" />
        <MudText Typo="Typo.h6">Completing bank connection...</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Please wait while we finish linking your account.
        </MudText>
    </MudStack>
</MudContainer>

@code {
    [Inject] private IJSRuntime JS { get; set; } = null!;
    [Inject] private NavigationManager Nav { get; set; } = null!;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Plaid Link will auto-resume the OAuth flow when re-initialized on this page
            // The plaid-link.js handles the callback via the receivedRedirectUri parameter
            await JS.InvokeVoidAsync("plaidLink.handleOAuthCallback", Nav.Uri);
        }
    }
}
